res <- gemss_select(X, Y, ns = 15, covtype = Cov_fun)
index_sub <- res$index
x.grid <- as.matrix(seq(0,1, 0.01))
y.grid <- gp_predict(x.grid, X[index_sub, ], Y[index_sub], Cov_fun, res$Parameters$theta, res$Parameters$g, res$Parameters$sigma2, res$Parameters$beta0)
plot(X, Y)
points(X[index_sub,], Y[index_sub], col = 2, pch = 19, cex= 2)
lines(x.grid, y.grid$mean, col =2 , lwd = 2)
