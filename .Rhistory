michalewicz  = function(xx){
x1 = xx[1]*pi
x2 = xx[2]*pi
m = 10
sum <- sin(x1) * (sin(1*x1^2/pi))^(2*m) + sin(x2) * (sin(2*x2^2/pi))^(2*m)
y <- -sum
return(y)
}
X <- matrix(runif(2000), 1000, 2)
Y = apply(X, 1, michalewicz) #+ rnorm(nrow(X), 0, 0.01)
Cov_fun <- 'Matern5_2'
res <- gemss_select(X, Y, ns = 80, covtype = Cov_fun)
index_sub <- res$index
ngrid <- 200
grid.x <- seq(0,1, len = ngrid)
grid <- as.matrix(expand.grid(x1 = grid.x, x2 = grid.x))
prep_grid <- gp_predict(grid, X[index_sub, ], Y[index_sub], Cov_fun, res$Parameters$theta, res$Parameters$g, res$Parameters$sigma2, res$Parameters$beta0)
cf_grid(grid.x,grid.x, matrix(prep_grid$mean,ngrid,ngrid),
bar=TRUE, main='',
afterplotfunc=function(){
points(X[,], col=1, pch='.',cex=6)
points(X[index_sub,], col='red', pch=4, cex=1.3, lwd = 2)
})
cf_grid(grid.x,grid.x, matrix(prep_grid$mean,ngrid,ngrid),
bar=TRUE, main='',
afterplotfunc=function(){
points(X[,], col=1, pch='.',cex=6)
points(X[index_sub,], col='blue', pch=1, cex=2, lwd = 2)
})
Rcpp::sourceCpp("src/GEMSS.cpp")
gp_predict <- function(X_new, X, Y, Cov_fun, Parameters) {
gp_predict_cpp(as.matrix(X_new), as.matrix(X), as.numeric(Y), Cov_fun, Parameters)
}
